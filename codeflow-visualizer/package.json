{
  "name": "codeflow-visualizer",
  "displayName": "CodeFlow Visualizer",
  "description": "Interactive visual diagram of your TypeScript/JavaScript code flow — functions, calls, params, and return types at a glance.",
  "version": "1.0.0",
  "publisher": "codeflow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codeflow/codeflow-visualizer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "codeflow",
    "diagram",
    "typescript",
    "graph",
    "call-graph",
    "visualizer"
  ],
  "activationEvents": [
    "onCommand:codeflow.showGraph",
    "onCommand:codeflow.showGraphForFile",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeflow.showGraph",
        "title": "CodeFlow: Show Interactive Flow Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "codeflow.showGraphForFile",
        "title": "CodeFlow: Show Flow Graph for This File",
        "icon": "$(references)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codeflow.showGraphForFile",
          "group": "navigation",
          "when": "resourceExtname == .ts || resourceExtname == .js"
        }
      ],
      "explorer/context": [
        {
          "command": "codeflow.showGraph",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codeflow.showGraph",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "configuration": {
      "title": "CodeFlow Visualizer",
      "properties": {
        "codeflow.includeNodeModules": {
          "type": "boolean",
          "default": false,
          "description": "Include node_modules in analysis (not recommended)"
        },
        "codeflow.maxDepth": {
          "type": "number",
          "default": 10,
          "description": "Maximum call depth to trace"
        },
        "codeflow.excludePatterns": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/out/**",
            "**/*.d.ts"
          ],
          "description": "Glob patterns to exclude from analysis"
        },
        "codeflow.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Groq (llama-3.3-70b-versatile) to generate smart flowcharts."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0"
  },
  "dependencies": {
    "typescript": "^5.3.0"
  }
}